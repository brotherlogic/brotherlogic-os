#!/usr/bin/env bash

# Tell this script to exit if there are any errors.
set -oue pipefail

# Sync configuration from /etc/skel to home directory
echo "Syncing configurations from /etc/skel..."
cp -rf /etc/skel/. "$HOME/" 2>/dev/null || true

# Set environment variables for better compatibility
export MOZ_ENABLE_WAYLAND=1
export _JAVA_AWT_WM_NONREPARENTING=1
export QT_QPA_PLATFORM=wayland
export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_DESKTOP=Hyprland
export XDG_SESSION_TYPE=wayland

# Adjust waybar config for desktop
CHASSIS=$(hostnamectl chassis)
if [ "$CHASSIS" != "laptop" ]; then
    if [ -f "$HOME/.config/waybar/config.desktop" ]; then
        echo "Detected non-laptop ($CHASSIS), applying desktop waybar config"
        mv -f "$HOME/.config/waybar/config.desktop" "$HOME/.config/waybar/config"
    fi
fi

# Prioritize local configuration
if [ -f "$HOME/.config/hypr/hyprland.conf" ]; then
    echo "Starting Hyprland with local config: $HOME/.config/hypr/hyprland.conf"
    exec Hyprland -c "$HOME/.config/hypr/hyprland.conf"
else
    echo "Local config not found, falling back to system default"
    default_conf="/usr/share/hyprland/hyprland.conf"
    exec Hyprland -c "$default_conf"
fi
